{
  "manifest_version": 3,
  "name": "Side panel",
  "version": "1.0.0",
  "description": "Show a persistent UI in the browser side panel with chrome.sidePanel.",
  "permissions": [
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
