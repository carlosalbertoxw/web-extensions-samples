{
  "manifest_version": 3,
  "name": "Options page",
  "version": "1.0.0",
  "description": "A dedicated options page that saves preferences with chrome.storage.sync.",
  "permissions": [
    "storage"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Settings",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
