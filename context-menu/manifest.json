{
  "manifest_version": 3,
  "name": "Context menu",
  "version": "1.0.0",
  "description": "Adds options to the right-click context menu.",
  "permissions": [
    "contextMenus",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
