{
  "manifest_version": 3,
  "name": "Web request blocking",
  "version": "1.0.0",
  "description": "Block or redirect network requests with declarativeNetRequest.",
  "permissions": [
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://example.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_title": "Settings",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
