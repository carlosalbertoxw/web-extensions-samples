{
  "manifest_version": 3,
  "name": "Tabs",
  "version": "1.0.0",
  "description": "List the open tabs and open a new one using chrome.tabs.",
  "permissions": [
    "tabs"
  ],
  "action": {
    "default_title": "Settings",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
