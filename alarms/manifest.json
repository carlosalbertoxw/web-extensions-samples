{
  "manifest_version": 3,
  "name": "Alarms",
  "version": "1.0.0",
  "description": "Schedule tasks with chrome.alarms (the MV3 replacement for setInterval).",
  "permissions": [
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Settings",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
