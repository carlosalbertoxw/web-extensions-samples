{
  "manifest_version": 3,
  "name": "Fetch API",
  "version": "1.0.0",
  "description": "Call an external API and show the result in the popup.",
  "host_permissions": [
    "https://dog.ceo/*"
  ],
  "action": {
    "default_title": "Settings",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
